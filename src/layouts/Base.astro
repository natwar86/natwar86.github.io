---
const {
  title = 'Natwar Maheshwari',
  description = 'Natwar Maheshwari builds data products: ConferenceGrid, Developer Educators, Trip Channels, and more. Engineer by training, marketer by profession, builder by choice.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={Astro.url} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="theme-color" content="#ffffff" id="meta-theme" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:image" content="https://natwar.com/og.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<script is:inline>
  (function () {
    var saved = localStorage.getItem('theme');
    if (saved === 'dark' || saved === 'light') {
      document.documentElement.dataset.theme = saved;
    }
  })();
</script>
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-NQVV4L0M4M"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-NQVV4L0M4M');
</script>
</head>
<body>
<button id="theme-toggle" aria-label="Toggle dark mode">◐</button>
<slot />
</body>
</html>

<style is:global>
  :root {
    --bg: #fff;
    --ink: #1c1c1c;
    --gray: #888;
    --soft: #666;
    --underline: #999;
    --code-bg: #f6f6f4;
  }
  :root[data-theme="dark"] {
    --bg: #1b1a18;
    --ink: #d8d5ce;
    --gray: #918d85;
    --soft: #918d85;
    --underline: #6f6c66;
    --code-bg: #262420;
  }

  body {
    font-family: Charter, Iowan, Georgia, serif;
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--ink);
    background: var(--bg);
    max-width: 39em;
    margin: 0 auto;
    padding: 5rem 1.25rem 7rem;
  }
  h1 { font-size: 1.875rem; font-weight: 700; margin: 0 0 0.2rem; }
  .centered { text-align: center; }
  h2 { font-size: 1.15rem; font-weight: normal; font-style: italic; margin: 3rem 0 1rem; }
  p { margin: 0 0 1.1em; }
  a { color: inherit; text-decoration-color: var(--underline); text-underline-offset: 2px; }
  a:hover { text-decoration-color: var(--ink); }
  ul { list-style: none; padding: 0; margin: 0 0 1.1em; }
  li { margin-bottom: 0.9em; }
  .date { color: var(--gray); font-size: 0.85em; }
  .pronounce { color: var(--gray); font-size: 0.85em; font-style: italic; margin: 0 0 0.3rem; }
  .idlinks { font-size: 0.9em; margin: 0 0 1.75rem; }
  .section-title { text-align: center; font-size: 1.4rem; }
  .projects li { margin-bottom: 1.3em; }
  .projects strong { font-weight: 600; }
  .state { color: var(--gray); font-size: 0.85em; font-style: italic; }
  footer { margin-top: 4rem; color: var(--soft); font-size: 0.9em; }
  pre {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 0.8em;
    line-height: 1.5;
    background: var(--code-bg);
    padding: 0.9em 1.1em;
    overflow-x: auto;
    margin: 0 0 1.3em;
  }
  code { font-family: ui-monospace, Menlo, monospace; font-size: 0.85em; background: var(--code-bg); padding: 0.1em 0.3em; }
  pre code { background: none; padding: 0; font-size: 1em; }

  #theme-toggle {
    position: fixed;
    top: 1rem;
    right: 1.25rem;
    background: none;
    border: none;
    padding: 0.25rem;
    cursor: pointer;
    font-size: 1.15rem;
    line-height: 1;
    color: var(--gray);
  }
  #theme-toggle:hover { color: var(--ink); }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    function current() {
      return document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
    }
    function paint() {
      var dark = current() === 'dark';
      btn.textContent = dark ? '☀︎' : '☾';
      document.getElementById('meta-theme').content = dark ? '#1b1a18' : '#ffffff';
    }
    btn.addEventListener('click', function () {
      var next = current() === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
      paint();
    });
    paint();
  })();
</script>
