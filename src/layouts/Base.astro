---
const { title = 'Natwar Maheshwari' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
</head>
<body>
<slot />
</body>
</html>

<style is:global>
  body {
    font-family: Charter, Iowan, Georgia, serif;
    font-size: 1.15rem;
    line-height: 1.65;
    color: #1c1c1c;
    background: #fff;
    max-width: 39em;
    margin: 0 auto;
    padding: 5rem 1.25rem 7rem;
  }
  h1 { font-size: 1.875rem; font-weight: 700; margin: 0 0 0.2rem; }
  .centered { text-align: center; }
  h2 { font-size: 1.15rem; font-weight: normal; font-style: italic; margin: 3rem 0 1rem; }
  p { margin: 0 0 1.1em; }
  a { color: inherit; text-decoration-color: #999; text-underline-offset: 2px; }
  a:hover { text-decoration-color: #1c1c1c; }
  ul { list-style: none; padding: 0; margin: 0 0 1.1em; }
  li { margin-bottom: 0.9em; }
  .date { color: #888; font-size: 0.85em; }
  .pronounce { color: #888; font-size: 0.85em; font-style: italic; margin: 0 0 0.3rem; }
  .idlinks { font-size: 0.9em; margin: 0 0 1.75rem; }
  .projects { font-size: 1.08em; }
  .projects li { margin-bottom: 1.4em; }
  .projects strong { font-weight: 600; font-size: 1.1em; }
  .state { color: #888; font-size: 0.85em; font-style: italic; }
  footer { margin-top: 4rem; color: #666; font-size: 0.9em; }
  pre {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 0.8em;
    line-height: 1.5;
    background: #f6f6f4;
    padding: 0.9em 1.1em;
    overflow-x: auto;
    margin: 0 0 1.3em;
  }
  code { font-family: ui-monospace, Menlo, monospace; font-size: 0.85em; background: #f6f6f4; padding: 0.1em 0.3em; }
  pre code { background: none; padding: 0; font-size: 1em; }
</style>
