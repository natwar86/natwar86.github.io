---
const {
  title = 'Natwar Maheshwari',
  description = 'Natwar Maheshwari builds data products: ConferenceGrid, Developer Educators, Trip Channels, and more. Engineer by training, marketer by profession, builder by choice.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={Astro.url} />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
<meta name="theme-color" content="#1b1a18" media="(prefers-color-scheme: dark)" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:image" content="https://natwar.com/og.png" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-NQVV4L0M4M"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-NQVV4L0M4M');
</script>
</head>
<body>
<slot />
</body>
</html>

<style is:global>
  body {
    font-family: Charter, Iowan, Georgia, serif;
    font-size: 1.15rem;
    line-height: 1.65;
    color: #1c1c1c;
    background: #fff;
    max-width: 39em;
    margin: 0 auto;
    padding: 5rem 1.25rem 7rem;
  }
  h1 { font-size: 1.875rem; font-weight: 700; margin: 0 0 0.2rem; }
  .centered { text-align: center; }
  h2 { font-size: 1.15rem; font-weight: normal; font-style: italic; margin: 3rem 0 1rem; }
  p { margin: 0 0 1.1em; }
  a { color: inherit; text-decoration-color: #999; text-underline-offset: 2px; }
  a:hover { text-decoration-color: #1c1c1c; }
  ul { list-style: none; padding: 0; margin: 0 0 1.1em; }
  li { margin-bottom: 0.9em; }
  .date { color: #888; font-size: 0.85em; }
  .pronounce { color: #888; font-size: 0.85em; font-style: italic; margin: 0 0 0.3rem; }
  .idlinks { font-size: 0.9em; margin: 0 0 1.75rem; }
  .section-title { text-align: center; font-size: 1.4rem; }
  .projects li { margin-bottom: 1.3em; }
  .projects strong { font-weight: 600; }
  .state { color: #888; font-size: 0.85em; font-style: italic; }
  footer { margin-top: 4rem; color: #666; font-size: 0.9em; }
  pre {
    font-family: ui-monospace, Menlo, monospace;
    font-size: 0.8em;
    line-height: 1.5;
    background: #f6f6f4;
    padding: 0.9em 1.1em;
    overflow-x: auto;
    margin: 0 0 1.3em;
  }
  code { font-family: ui-monospace, Menlo, monospace; font-size: 0.85em; background: #f6f6f4; padding: 0.1em 0.3em; }
  pre code { background: none; padding: 0; font-size: 1em; }

  @media (prefers-color-scheme: dark) {
    body { background: #1b1a18; color: #d8d5ce; }
    a { text-decoration-color: #6f6c66; }
    a:hover { text-decoration-color: #d8d5ce; }
    .pronounce, .date, .state, footer { color: #918d85; }
    pre, code { background: #262420; }
  }
</style>
