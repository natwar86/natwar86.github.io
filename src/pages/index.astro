---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---
<Base>

<h1>Natwar Maheshwari</h1>
<p class="pronounce">nut-vur mah-haysh-wuh-ree</p>
<p class="idlinks">
  <a href="https://github.com/natwar86">github</a> ·
  <a href="https://www.linkedin.com/in/natwar/">linkedin</a> ·
  <a href="https://x.com/natwar86">x</a>
</p>

<p>I'm an engineer by training, a marketer by profession, and a builder by
choice. I've worked as a hardware and software engineer, built and sold a SaaS
company, and I specialize in marketing developer-first products.</p>

<p>Since January 2026 I've been building a lot more on the side. The goal is
to keep learning new things and keep shipping. The current project is
<a href="https://conferencegrid.com">ConferenceGrid</a>, a conference database
for B2B teams.</p>

<p>If you want to build something together, say hi on
<a href="https://x.com/natwar86">X</a> or
<a href="https://www.linkedin.com/in/natwar/">LinkedIn</a>.</p>

<h2>Projects</h2>

<p>I like building data products. Here are some that have been interesting
so far.</p>

<ul class="projects">
  <li><strong><a href="https://conferencegrid.com">ConferenceGrid</a></strong>
  <span class="state">live</span><br>
  Type a company, see every conference it sponsors, speaks at, or exhibits at.
  6,000+ conferences, 84,000 speakers, one graph.</li>

  <li><strong><a href="https://developereducators.com">Developer Educators</a></strong>
  <span class="state">live</span><br>
  A directory of 5,000+ YouTube channels that teach programming, with
  engagement metrics, updated daily.</li>

  <li><strong><a href="https://tripchannels.com">Trip Channels</a></strong>
  <span class="state">live</span><br>
  A field guide to travel YouTubers: 2,080 channels organized by where they
  actually go. 41 countries, 15 travel styles.</li>

  <li><strong><a href="https://github.com/natwar86/foropensource">For Open Source</a></strong>
  <span class="state">live</span><br>
  A community-maintained list of free products, services, and money for open
  source. 163 companies, each one verified.</li>

  <li><strong>Podcasts</strong>
  <span class="state">in progress</span><br>
  A new directory, still taking shape. More here soon.</li>

  <li><strong><a href="https://subprocessors.xyz">SubProcessors</a></strong>
  <span class="state">paused</span><br>
  A directory of who processes your data: 13,000 vendor relationships from
  public subprocessor lists. Paused while I rethink the architecture, but the
  data exists. <a href="https://x.com/natwar86">Ask me</a> if you want it.</li>

  <li><strong><a href="https://github.com/natwar86/signal-listener">Signal Listener</a></strong>
  <span class="state">shipped</span><br>
  Watches reviews, Reddit, and other public feeds for sales signals. Built for
  Saltbox.</li>

  <li><strong><a href="https://gtmtools.dev">GTM Tools</a></strong>
  <span class="state">live</span><br>
  326 API-first tools for revenue teams, in one searchable place.</li>

  <li><strong><a href="https://investorconnect.xyz">Investor Connect</a></strong>
  <span class="state">live</span><br>
  A database of 40,000+ vetted startup investors, angels, and VCs.</li>

  <li><strong><a href="https://github.com/natwar86/session-continuity">Session Continuity</a></strong>
  <span class="state">on GitHub</span><br>
  A Claude Code skill that saves session state, so a new session picks up
  where the last one stopped. It helped build this site.</li>
</ul>

{posts.length > 0 && (
  <>
    <h2>Writing</h2>
    <ul>
      {posts.map((post) => (
        <li>
          <a href={`/writing/${post.id}/`}>{post.data.title}</a><br />
          <span class="date">{fmt(post.data.date)}</span>
        </li>
      ))}
    </ul>
  </>
)}

</Base>
